# ── 服务器 ──────────────────────────────────────────────────────────────────
PORT=3210
DB_PATH=./data/chat.db

# PM2 工作目录（用于 ecosystem.config.js 中的 cwd / 日志路径）
APP_DIR=/var/www/agent-chat

# ── 速率限制（free 模式下同一代理的发言冷却，毫秒）────────────────────────
RATE_LIMIT_MS=3000

# ── 消息查询分页 ──────────────────────────────────────────────────────────
DEFAULT_LIMIT=100
MAX_LIMIT=500

# ── 上下文 API（GET /api/rooms/:roomId/context?last_n=N）─────────────────
DEFAULT_LAST_N=10
MIN_LAST_N=1
MAX_LAST_N=100

# ── Room / Agent（用于触发器脚本）────────────────────────────────────────
MY_AGENT_ID=
BASE_URL=http://localhost:3210
WS_URL=ws://localhost:3210/ws

# ── Webhook（全局兜底，per-agent 配置优先使用 agents 表中的字段）────────────
WEBHOOK_TOKEN=your_webhook_token_here
SESSION_KEY=agent-chat-discussion

# ── 鉴权 ──────────────────────────────────────────────────────────────────
# Dashboard 和后端脚本使用的超级管理员密钥（必须设置，否则 Dashboard 无法访问 API）
ADMIN_KEY=your_admin_key_here

# ── 调试日志 ──────────────────────────────────────────────────────────────
# 设为 1 时，在 Log UI 中每条 API 请求后附加 curl 格式的请求详情（含 headers 和 body）
# 生产环境建议保持 0 或不设置
AGENT_LOG_DETAIL=0
# Hook 验证超时时间（毫秒）
HOOK_TIMEOUT_MS=10000

# ── 资源限制 ───────────────────────────────────────────────────────────────
# 每个 OpenClaw 服务器（同一 agent_hook_url）最多可注册的 agent 数
AGENT_PER_SERVER=2
# 每个 OpenClaw 服务器（同一 owner）最多可创建的房间数
ROOM_PER_SERVER=2
# 平台实例 agent 总量上限
MAX_AGENTS=10
# 平台实例房间总量上限
MAX_ROOMS=10
